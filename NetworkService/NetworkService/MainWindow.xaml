<Window x:Class="NetworkService.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:viewModel="clr-namespace:NetworkService.ViewModel"
        Title="NetworkService"
        Height="780" Width="390"
        MinHeight="780" MinWidth="390"
        MaxHeight="780" MaxWidth="390"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F5F5F5">

    <Window.DataContext>
        <viewModel:MainWindowViewModel/>
    </Window.DataContext>

    <Window.InputBindings>
        <KeyBinding Key="D1" Modifiers="Alt" Command="{Binding NavigateNetworkCommand}"/>
        <KeyBinding Key="D2" Modifiers="Alt" Command="{Binding NavigateEntitiesCommand}"/>
        <KeyBinding Key="D3" Modifiers="Alt" Command="{Binding NavigateGraphCommand}"/>
        <KeyBinding Key="Home" Command="{Binding NavigateHomeCommand}"/>
        <KeyBinding Key="Z" Modifiers="Ctrl" Command="{Binding UndoCommand}"/>
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <!-- Header -->
            <RowDefinition Height="*"/>
            <!-- Content -->
            <RowDefinition Height="70"/>
            <!-- Bottom nav -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════ HEADER ═══════════════════════════════ -->
        <Border Grid.Row="0" Background="#1E1E2E" Padding="16,0">
            <Grid>
                <TextBlock Text="{Binding CurrentViewTitle}"
                           Foreground="White"
                           FontSize="18"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
                <!-- Home dugme (vidljivo na svim View-ovima osim Home) -->
                <Button HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Command="{Binding NavigateHomeCommand}"
                        Visibility="{Binding HomeButtonVisibility}"
                        Style="{StaticResource IconButtonStyle}"
                        ToolTip="Go to Home (Home key)">
                    <TextBlock Text="🏠" FontSize="20"/>
                </Button>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════ CONTENT ══════════════════════════════ -->
        <ContentControl Grid.Row="1"
                        Content="{Binding CurrentView}"
                        Margin="0"/>

        <!-- ═══════════════════════════════ BOTTOM NAV ═══════════════════════════ -->
        <Border Grid.Row="2" Background="#1E1E2E">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Network -->
                <Button Grid.Column="0"
                        Command="{Binding NavigateNetworkCommand}"
                        Style="{StaticResource NavButtonStyle}"
                        ToolTip="Network Display (Alt+1)">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="&#xE80F;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="22" HorizontalAlignment="Center"
                                   Foreground="{Binding NetworkNavColor}"/>
                        <TextBlock Text="Network" FontSize="11"
                                   Foreground="{Binding NetworkNavColor}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Entities -->
                <Button Grid.Column="1"
                        Command="{Binding NavigateEntitiesCommand}"
                        Style="{StaticResource NavButtonStyle}"
                        ToolTip="Entities List (Alt+2)">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="&#xE8A9;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="22" HorizontalAlignment="Center"
                                   Foreground="{Binding EntitiesNavColor}"/>
                        <TextBlock Text="Entities" FontSize="11"
                                   Foreground="{Binding EntitiesNavColor}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Graph -->
                <Button Grid.Column="2"
                        Command="{Binding NavigateGraphCommand}"
                        Style="{StaticResource NavButtonStyle}"
                        ToolTip="Graph View (Alt+3)">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="&#xE9D2;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="22" HorizontalAlignment="Center"
                                   Foreground="{Binding GraphNavColor}"/>
                        <TextBlock Text="Graph" FontSize="11"
                                   Foreground="{Binding GraphNavColor}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>
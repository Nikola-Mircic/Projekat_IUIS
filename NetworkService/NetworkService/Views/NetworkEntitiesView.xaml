<UserControl x:Class="NetworkService.Views.NetworkEntitiesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:NetworkService.ViewModel"
             Background="#F5F5F5">

    <UserControl.DataContext>
        <vm:NetworkEntitiesViewModel/>
    </UserControl.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Filter sekcija -->
            <RowDefinition Height="*"/>
            <!-- Tabela -->
            <RowDefinition Height="Auto"/>
            <!-- Add forma -->
            <RowDefinition Height="60"/>
            <!-- Undo dugme -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════ FILTER SEKCIJA ═══════════════════ -->
        <Border Grid.Row="0" Background="White" Margin="12,12,12,6"
                CornerRadius="12" Padding="12">
            <StackPanel>
                <Grid Margin="0,0,0,8">
                    <TextBlock Text="Filter" FontSize="15" FontWeight="SemiBold"
                               Foreground="#1E1E2E" VerticalAlignment="Center"/>
                    <Button HorizontalAlignment="Right"
                            Command="{Binding ClearFilterCommand}"
                            Style="{StaticResource SmallButtonStyle}"
                            ToolTip="Clear all filters">
                        <TextBlock Text="Clear"/>
                    </Button>
                </Grid>

                <!-- Server type ComboBox -->
                <TextBlock Text="Server type:" FontSize="12" Foreground="#6B7280" Margin="0,0,0,4"/>
                <ComboBox ItemsSource="{Binding ServerTypes}"
                          SelectedItem="{Binding SelectedServerType}"
                          DisplayMemberPath="Name"
                          FontSize="14" Margin="0,0,0,10"
                          Style="{StaticResource ComboBoxStyle}"
                          ToolTip="Filter by server type"/>

                <!-- ID filter -->
                <TextBlock Text="ID filter:" FontSize="12" Foreground="#6B7280" Margin="0,0,0,6"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- RadioButtons -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <RadioButton Content="&gt;" Margin="0,0,16,0"
                                     IsChecked="{Binding IsGreaterThan}"
                                     GroupName="IdFilter"
                                     FontSize="14" Foreground="#1E1E2E"
                                     ToolTip="ID greater than"/>
                        <RadioButton Content="&lt;" Margin="0,0,16,0"
                                     IsChecked="{Binding IsLessThan}"
                                     GroupName="IdFilter"
                                     FontSize="14" Foreground="#1E1E2E"
                                     ToolTip="ID less than"/>
                        <RadioButton Content="=" Margin="0,0,16,0"
                                     IsChecked="{Binding IsEqualTo}"
                                     GroupName="IdFilter"
                                     FontSize="14" Foreground="#1E1E2E"
                                     ToolTip="ID equal to"/>
                    </StackPanel>

                    <!-- ID TextBox sa virtualnom tastaturom -->
                    <TextBox Grid.Column="2"
                             Text="{Binding IdFilterText, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="14" IsReadOnly="True"
                             Style="{StaticResource TextBoxStyle}"
                             ToolTip="Enter ID value — tap to open keypad">
                        <TextBox.InputBindings>
                            <MouseBinding MouseAction="LeftClick"
                                          Command="{Binding ShowKeyboardCommand}"
                                          CommandParameter="IdFilter"/>
                        </TextBox.InputBindings>
                    </TextBox>
                </Grid>

                <!-- Poruka o grešci za ID filter -->
                <TextBlock Text="{Binding IdFilterError}"
                           Foreground="#DC2626" FontSize="11"
                           Margin="0,2,0,0"
                           Visibility="{Binding IdFilterError,
                               Converter={StaticResource StringToVisibilityConverter}}"/>

                <!-- Apply dugme -->
                <Button Margin="0,10,0,0"
                        Command="{Binding ApplyFilterCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        ToolTip="Apply filter (Enter)">
                    <TextBlock Text="Apply"/>
                </Button>
            </StackPanel>
        </Border>

        <!-- ═══════════════════ TABELA ═══════════════════ -->
        <Border Grid.Row="1" Background="White" Margin="12,6,12,6"
                CornerRadius="12" Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header tabele + Add/Delete dugmad -->
                <Grid Grid.Row="0" Margin="12,10,12,6">
                    <TextBlock Text="Server list" FontSize="14" FontWeight="SemiBold"
                               Foreground="#1E1E2E" VerticalAlignment="Center"/>
                    <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                        <Button Command="{Binding AddEntityCommand}"
                                Margin="0,0,8,0"
                                Style="{StaticResource SmallButtonStyle}"
                                ToolTip="Add new server entity">
                            <TextBlock Text="Add"/>
                        </Button>
                        <Button Command="{Binding DeleteEntityCommand}"
                                Style="{StaticResource DangerButtonStyle}"
                                ToolTip="Delete selected server entity">
                            <TextBlock Text="Delete"/>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- DataGrid -->
                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding FilteredEntities}"
                          SelectedItem="{Binding SelectedEntity}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column"
                          Background="Transparent"
                          BorderThickness="0"
                          RowBackground="White"
                          AlternatingRowBackground="#F9FAFB"
                          CanUserResizeColumns="False"
                          CanUserSortColumns="True"
                          FontSize="12">

                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#F3F4F6"/>
                            <Setter Property="Foreground" Value="#6B7280"/>
                            <Setter Property="FontSize" Value="11"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding" Value="8,6"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="BorderBrush" Value="#E5E7EB"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID"
                                            Binding="{Binding Id}"
                                            Width="40"/>
                        <DataGridTextColumn Header="Name"
                                            Binding="{Binding Name}"
                                            Width="*"/>
                        <DataGridTextColumn Header="Type"
                                            Binding="{Binding Type.Name}"
                                            Width="80"/>
                        <DataGridTextColumn Header="IP"
                                            Binding="{Binding IpAddress}"
                                            Width="90"/>
                        <DataGridTemplateColumn Header="Load %" Width="65">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding LastMeasuredValue, StringFormat={}{0:F1}%}"
                                               Foreground="{Binding IsOutOfRange,
                                                   Converter={StaticResource BoolToColorConverter}}"
                                               FontWeight="Medium"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>

                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#EDE9FE"/>
                                    <Setter Property="BorderBrush" Value="#7C3AED"/>
                                </Trigger>
                                <DataTrigger Binding="{Binding IsOutOfRange}" Value="True">
                                    <Setter Property="Foreground" Value="#DC2626"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                </DataGrid>
            </Grid>
        </Border>

        <!-- ═══════════════════ ADD FORMA ═══════════════════ -->
        <Border Grid.Row="2" Background="White" Margin="12,6,12,6"
                CornerRadius="12" Padding="12"
                Visibility="{Binding IsAddFormVisible,
                    Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel>
                <TextBlock Text="New server" FontSize="14" FontWeight="SemiBold"
                           Foreground="#1E1E2E" Margin="0,0,0,10"/>

                <!-- ID -->
                <TextBlock Text="ID" FontSize="12" Foreground="#6B7280" Margin="0,0,0,2"/>
                <TextBox Text="{Binding NewEntityId, UpdateSourceTrigger=PropertyChanged}"
                         IsReadOnly="True"
                         Style="{StaticResource TextBoxStyle}"
                         ToolTip="Tap to enter ID using keypad">
                    <TextBox.InputBindings>
                        <MouseBinding MouseAction="LeftClick"
                                      Command="{Binding ShowKeyboardCommand}"
                                      CommandParameter="NewId"/>
                    </TextBox.InputBindings>
                </TextBox>
                <TextBlock Text="{Binding NewEntityIdError}"
                           Foreground="#DC2626" FontSize="11" Margin="0,2,0,6"
                           Visibility="{Binding NewEntityIdError,
                               Converter={StaticResource StringToVisibilityConverter}}"/>

                <!-- Name -->
                <TextBlock Text="Name" FontSize="12" Foreground="#6B7280" Margin="0,0,0,2"/>
                <TextBox Text="{Binding NewEntityName, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource TextBoxStyle}"
                         ToolTip="Enter server name"/>
                <TextBlock Text="{Binding NewEntityNameError}"
                           Foreground="#DC2626" FontSize="11" Margin="0,2,0,6"
                           Visibility="{Binding NewEntityNameError,
                               Converter={StaticResource StringToVisibilityConverter}}"/>

                <!-- IP Address -->
                <TextBlock Text="IP Address" FontSize="12" Foreground="#6B7280" Margin="0,0,0,2"/>
                <TextBox Text="{Binding NewEntityIp, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource TextBoxStyle}"
                         ToolTip="Enter IP address (e.g. 192.168.1.10)"/>
                <TextBlock Text="{Binding NewEntityIpError}"
                           Foreground="#DC2626" FontSize="11" Margin="0,2,0,6"
                           Visibility="{Binding NewEntityIpError,
                               Converter={StaticResource StringToVisibilityConverter}}"/>

                <!-- Type -->
                <TextBlock Text="Type" FontSize="12" Foreground="#6B7280" Margin="0,0,0,2"/>
                <ComboBox ItemsSource="{Binding ServerTypes}"
                          SelectedItem="{Binding NewEntityType}"
                          DisplayMemberPath="Name"
                          Style="{StaticResource ComboBoxStyle}"
                          ToolTip="Select server type"/>
                <TextBlock Text="{Binding NewEntityTypeError}"
                           Foreground="#DC2626" FontSize="11" Margin="0,2,0,6"
                           Visibility="{Binding NewEntityTypeError,
                               Converter={StaticResource StringToVisibilityConverter}}"/>

                <!-- Dugmad -->
                <Grid Margin="0,6,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0"
                            Command="{Binding ConfirmAddCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            ToolTip="Confirm adding entity">
                        <TextBlock Text="Confirm"/>
                    </Button>
                    <Button Grid.Column="2"
                            Command="{Binding CancelAddCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            ToolTip="Cancel">
                        <TextBlock Text="Cancel"/>
                    </Button>
                </Grid>
            </StackPanel>
        </Border>

        <!-- ═══════════════════ UNDO DUGME ═══════════════════ -->
        <Grid Grid.Row="3" Margin="12,0,12,8">
            <Button HorizontalAlignment="Right" VerticalAlignment="Bottom"
                    Command="{Binding UndoCommand}"
                    Style="{StaticResource UndoButtonStyle}"
                    ToolTip="Undo last action (Ctrl+Z)">
                <TextBlock Text="↩" FontSize="22"/>
            </Button>
        </Grid>

        <!-- ═══════════════════ VIRTUELNA TASTATURA ═══════════════════ -->
        <Border Grid.Row="0" Grid.RowSpan="4"
                Background="#80000000" CornerRadius="0"
                Visibility="{Binding IsKeyboardVisible,
                    Converter={StaticResource BoolToVisibilityConverter}}">
            <Border Background="White" CornerRadius="16"
                    Padding="16" VerticalAlignment="Bottom"
                    Margin="12,0,12,12" MaxWidth="340">
                <StackPanel>
                    <UniformGrid Rows="4" Columns="3" >
                        <!-- Row 1 -->
                        <Button Content="1" Command="{Binding KeyPressCommand}" CommandParameter="1" Style="{StaticResource KeypadButtonStyle}"/>
                        <Button Content="2" Command="{Binding KeyPressCommand}" CommandParameter="2" Style="{StaticResource KeypadButtonStyle}"/>
                        <Button Content="3" Command="{Binding KeyPressCommand}" CommandParameter="3" Style="{StaticResource KeypadButtonStyle}"/>
                        <!-- Row 2 -->
                        <Button Content="4" Command="{Binding KeyPressCommand}" CommandParameter="4" Style="{StaticResource KeypadButtonStyle}"/>
                        <Button Content="5" Command="{Binding KeyPressCommand}" CommandParameter="5" Style="{StaticResource KeypadButtonStyle}"/>
                        <Button Content="6" Command="{Binding KeyPressCommand}" CommandParameter="6" Style="{StaticResource KeypadButtonStyle}"/>
                        <!-- Row 3 -->
                        <Button Content="7" Command="{Binding KeyPressCommand}" CommandParameter="7" Style="{StaticResource KeypadButtonStyle}"/>
                        <Button Content="8" Command="{Binding KeyPressCommand}" CommandParameter="8" Style="{StaticResource KeypadButtonStyle}"/>
                        <Button Content="9" Command="{Binding KeyPressCommand}" CommandParameter="9" Style="{StaticResource KeypadButtonStyle}"/>
                        <!-- Row 4 -->
                        <Button Content="0" Command="{Binding KeyPressCommand}" CommandParameter="0" Style="{StaticResource KeypadButtonStyle}"/>
                        <Button Content="OK" Command="{Binding KeyboardOkCommand}" Style="{StaticResource KeypadOkButtonStyle}"/>
                        <Button Content="⌫" Command="{Binding KeyboardBackspaceCommand}" Style="{StaticResource KeypadButtonStyle}"/>
                    </UniformGrid>
                </StackPanel>
            </Border>
        </Border>

    </Grid>
</UserControl>
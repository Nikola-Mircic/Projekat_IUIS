<UserControl x:Class="NetworkService.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F5F5F5">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>

        <!-- Network Display -->
        <Button Grid.Row="0" Margin="0,12"
                Command="{Binding DataContext.NavigateNetworkCommand,
                          RelativeSource={RelativeSource AncestorType=Window}}"
                Style="{StaticResource HomeNavButtonStyle}"
                ToolTip="Open Network Display view">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="&#xE80F;" FontFamily="Segoe MDL2 Assets"
                           FontSize="48" HorizontalAlignment="Center"
                           Foreground="#1E1E2E"/>
                <TextBlock Text="Network display" FontSize="16"
                           FontWeight="Medium" Foreground="#1E1E2E"
                           HorizontalAlignment="Center" Margin="0,8,0,0"/>
            </StackPanel>
        </Button>

        <!-- Entities Display -->
        <Button Grid.Row="1" Margin="0,12"
                Command="{Binding DataContext.NavigateEntitiesCommand,
                          RelativeSource={RelativeSource AncestorType=Window}}"
                Style="{StaticResource HomeNavButtonStyle}"
                ToolTip="Open Entities list view">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="&#xE8A9;" FontFamily="Segoe MDL2 Assets"
                           FontSize="48" HorizontalAlignment="Center"
                           Foreground="#1E1E2E"/>
                <TextBlock Text="Entities display" FontSize="16"
                           FontWeight="Medium" Foreground="#1E1E2E"
                           HorizontalAlignment="Center" Margin="0,8,0,0"/>
            </StackPanel>
        </Button>

        <!-- Graph View -->
        <Button Grid.Row="2" Margin="0,12"
                Command="{Binding DataContext.NavigateGraphCommand,
                          RelativeSource={RelativeSource AncestorType=Window}}"
                Style="{StaticResource HomeNavButtonStyle}"
                ToolTip="Open Graph view">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="&#xE9D2;" FontFamily="Segoe MDL2 Assets"
                           FontSize="48" HorizontalAlignment="Center"
                           Foreground="#1E1E2E"/>
                <TextBlock Text="Graph view" FontSize="16"
                           FontWeight="Medium" Foreground="#1E1E2E"
                           HorizontalAlignment="Center" Margin="0,8,0,0"/>
            </StackPanel>
        </Button>

        <!-- Undo dugme -->
        <Button Grid.Row="3"
                HorizontalAlignment="Right" VerticalAlignment="Bottom"
                Command="{Binding DataContext.UndoCommand,
                          RelativeSource={RelativeSource AncestorType=Window}}"
                Style="{StaticResource UndoButtonStyle}"
                ToolTip="Undo last action (Ctrl+Z)">
            <TextBlock Text="↩" FontSize="22"/>
        </Button>
    </Grid>
</UserControl>
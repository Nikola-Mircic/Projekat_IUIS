<UserControl x:Class="NetworkService.Views.GraphView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:NetworkService.ViewModel"
             Background="#F5F5F5">

    <UserControl.DataContext>
        <vm:GraphViewModel/>
    </UserControl.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Server izbor -->
            <RowDefinition Height="*"/>
            <!-- Graf -->
            <RowDefinition Height="Auto"/>
            <!-- Legenda -->
            <RowDefinition Height="60"/>
            <!-- Undo dugme -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════ SERVER IZBOR ═══════════════════ -->
        <Border Grid.Row="0" Background="White"
                Margin="12,12,12,6" CornerRadius="12" Padding="12">
            <StackPanel>
                <TextBlock Text="Select server:"
                           FontSize="15" FontWeight="SemiBold"
                           Foreground="#1E1E2E" Margin="0,0,0,8"/>
                <ComboBox ItemsSource="{Binding Entities}"
                      SelectedItem="{Binding SelectedEntity}"
                      Style="{StaticResource ComboBoxStyle}"
                      ToolTip="Select a server to view its measurement history">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>
        </Border>

        <!-- ═══════════════════ G2 BAR GRAFIKON ═══════════════════ -->
        <Border Grid.Row="1" Background="White"
                Margin="12,6,12,6" CornerRadius="12" Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- Y osa labela -->
                    <RowDefinition Height="*"/>
                    <!-- Graf area -->
                    <RowDefinition Height="24"/>
                    <!-- X osa -->
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="36"/>
                    <!-- Y osa -->
                    <ColumnDefinition Width="*"/>
                    <!-- Graf -->
                </Grid.ColumnDefinitions>

                <!-- Y osa labela -->
                <TextBlock Grid.Row="0" Grid.Column="0"
                           Grid.RowSpan="2"
                           Text="Load (%)"
                           FontSize="10" Foreground="#6B7280"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center">
                    <TextBlock.LayoutTransform>
                        <RotateTransform Angle="-90"/>
                    </TextBlock.LayoutTransform>
                </TextBlock>

                <!-- Y osa podeoci -->
                <ItemsControl Grid.Row="1" Grid.Column="0"
                              ItemsSource="{Binding YAxisLabels}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Canvas/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Label}"
                                       FontSize="9" Foreground="#9CA3AF"
                                       Canvas.Left="0"
                                       Canvas.Top="{Binding YPosition}"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Glavni Canvas za barove -->
                <Canvas Grid.Row="1" Grid.Column="1"
                        x:Name="BarCanvas"
                        Background="Transparent"
                        SizeChanged="BarCanvas_SizeChanged">

                    <!-- Horizontalne grid linije -->
                    <ItemsControl ItemsSource="{Binding GridLines}"
                             Canvas.Left="0" Canvas.Top="0">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Canvas.Left" Value="0"/>
                                <Setter Property="Canvas.Top" Value="0"/>
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Line X1="{Binding X1}" Y1="{Binding Y1}"
                                  X2="{Binding X2}" Y2="{Binding Y2}"
                                  Stroke="#F3F4F6" StrokeThickness="1"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Barovi -->
                    <ItemsControl ItemsSource="{Binding Bars}"
                            Canvas.Left="0" Canvas.Top="0">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Canvas.Left" Value="{Binding X}"/>
                                <Setter Property="Canvas.Top"  Value="{Binding Y}"/>
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Rectangle Width="{Binding Width}"
                                   Height="{Binding Height}"
                                   Fill="{Binding Color}"
                                   RadiusX="3" RadiusY="3">
                                    <Rectangle.ToolTip>
                                        <ToolTip>
                                            <TextBlock Text="{Binding TooltipText}"/>
                                        </ToolTip>
                                    </Rectangle.ToolTip>
                                </Rectangle>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    
                    <!-- Vrednosti iznad barova -->
                    <ItemsControl ItemsSource="{Binding Bars}"
                        Canvas.Left="0" Canvas.Top="0">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Canvas.Left" Value="{Binding X}"/>
                                <Setter Property="Canvas.Top"  Value="{Binding ValueLabelY}"/>
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding ValueLabel}"
                                   FontSize="9" FontWeight="SemiBold"
                                   Foreground="#1E1E2E"
                                   TextAlignment="Center"
                                   Width="{Binding Width}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Granična linija 45% -->
                    <Line X1="0" Y1="{Binding MinBoundaryY}"
                          X2="{Binding CanvasWidth}" Y2="{Binding MinBoundaryY}"
                          Stroke="#16A34A" StrokeThickness="1"
                          StrokeDashArray="6,3"/>

                    <!-- Granična linija 75% -->
                    <Line X1="0" Y1="{Binding MaxBoundaryY}"
                          X2="{Binding CanvasWidth}" Y2="{Binding MaxBoundaryY}"
                          Stroke="#16A34A" StrokeThickness="1"
                          StrokeDashArray="6,3"/>
                </Canvas>

                <!-- X osa oznake -->
                <Canvas Grid.Row="2" Grid.Column="1" Height="24">
                    <ItemsControl ItemsSource="{Binding Bars}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Canvas.Left" Value="{Binding X}"/>
                                <Setter Property="Canvas.Top"  Value="4"/>
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding TimeLabel}"
                           FontSize="9" Foreground="#9CA3AF"
                           TextAlignment="Center"
                           Width="{Binding Width}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Canvas>

                <!-- X osa linija -->
                <Border Grid.Row="2" Grid.Column="1"
                        BorderBrush="#E5E7EB"
                        BorderThickness="0,1,0,0"
                        VerticalAlignment="Top"/>

            </Grid>
        </Border>

        <!-- ═══════════════════ LEGENDA ═══════════════════ -->
        <Border Grid.Row="2" Background="White"
                Margin="12,6,12,6" CornerRadius="12" Padding="12,8">
            <StackPanel>

                <!-- Info o selektovanom serveru -->
                <Grid Margin="0,0,0,8"
                      Visibility="{Binding SelectedEntity,
                          Converter={StaticResource NullToVisibilityConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="{Binding SelectedEntity.Name}"
                               FontSize="13" FontWeight="SemiBold"
                               Foreground="#1E1E2E" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1"
                               Text="{Binding SelectedEntity.IpAddress}"
                               FontSize="12" Foreground="#6B7280"
                               VerticalAlignment="Center"/>
                </Grid>

                <!-- Lista poslednjih 5 merenja -->
                <ItemsControl ItemsSource="{Binding RecentMeasurements}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="55"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="45"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Text="{Binding TimeLabel}"
                                           FontSize="11" Foreground="#6B7280"
                                           VerticalAlignment="Center"/>

                                <!-- Progress bar -->
                                <Border Grid.Column="1"
                                        Background="#F3F4F6"
                                        CornerRadius="3" Height="8"
                                        VerticalAlignment="Center"
                                        Margin="4,0">
                                    <Border CornerRadius="3"
                                            HorizontalAlignment="Left"
                                            Height="8"
                                            Background="{Binding BarColor}"
                                            Width="{Binding ProgressWidth}"/>
                                </Border>

                                <TextBlock Grid.Column="2"
                                           Text="{Binding ValueText}"
                                           FontSize="11" FontWeight="Medium"
                                           Foreground="{Binding TextColor}"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Legenda boja -->
                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                    <Rectangle Width="12" Height="12" Fill="#16A34A"
                               RadiusX="2" RadiusY="2" Margin="0,0,4,0"/>
                    <TextBlock Text="Valid (45–75%)" FontSize="11"
                               Foreground="#6B7280" Margin="0,0,16,0"/>
                    <Rectangle Width="12" Height="12" Fill="#DC2626"
                               RadiusX="2" RadiusY="2" Margin="0,0,4,0"/>
                    <TextBlock Text="Out of range" FontSize="11"
                               Foreground="#6B7280"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ═══════════════════ UNDO DUGME ═══════════════════ -->
        <Grid Grid.Row="3" Margin="12,0,12,8">
            <Button HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Command="{Binding UndoCommand}"
                    Style="{StaticResource UndoButtonStyle}"
                    ToolTip="Undo last action (Ctrl+Z)">
                <TextBlock Text="↩" FontSize="22"/>
            </Button>
        </Grid>

    </Grid>
</UserControl>